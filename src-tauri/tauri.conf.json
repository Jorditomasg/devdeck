{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevDeck",
  "version": "0.9.0",
  "identifier": "es.orizon.devdeck",
  "build": {
    "beforeDevCommand": "npm run start",
    "devUrl": "http://localhost:4200",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist/devops-manager/browser"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DevDeck",
        "width": 1300,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 650,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "publisher": "Jorditomasg",
    "resources": {
      "../config/repo-types/": "config/repo-types/"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  }
}
